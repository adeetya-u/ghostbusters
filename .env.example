# Nebius LLM - optional, for suggested reply generation
NEBIUS_API_KEY=your_nebius_api_key_here

# HydraDB - get your key at https://app.hydradb.com
HYDRA_DB_API_KEY=your_api_key_here
HYDRA_TENANT_ID=ghostbusters
HYDRA_SUB_TENANT_ID=default

# iMessage database (macOS only, requires Full Disk Access)
IMESSAGE_DB_PATH=~/Library/Messages/chat.db

# Connector API
CONNECTOR_HOST=127.0.0.1
CONNECTOR_PORT=8787

# Frontend dev server proxies to this URL
VITE_API_URL=http://127.0.0.1:8787
